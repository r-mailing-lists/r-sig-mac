            stop(msg, call. = FALSE)
        }
        if (.rs.installPackagesRequiresRestart(pkgs)) {
            response <- .rs.askForRestart("install.packages")
            if (identical(response, TRUE)) {
                call <- do.call(substitute, list(match.call(), 
